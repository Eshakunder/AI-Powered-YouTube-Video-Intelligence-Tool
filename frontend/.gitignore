# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- SECRETS (The most important part) ---
.env
.env.*
*.json
# This covers firebase.js in the root OR any subfolder
**/firebase.js
!package.json          # Don't ignore these essential config files
!tsconfig.json
!manifest.json
firebase-key.json      # Specifically block Firebase keys

# --- Python & FastAPI ---
__pycache__/
*.py[cod]
venv/
.venv/
.pytest_cache/

# --- Dependencies & Build ---
node_modules/
/build
/dist
/coverage
.pnp
.pnp.js


# --- Logs & OS ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db